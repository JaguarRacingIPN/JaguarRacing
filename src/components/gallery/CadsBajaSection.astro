---
// CadsBajaSection.astro
---

<section class="cads-hero">
    <div class="cads-hero__bg-grid"></div>
    <div class="cads-hero__inner">
        <a href="/gallery" class="cads-back">
            <span class="cads-back__arrow">&#8592;</span>
            <span>Galer&#237;a</span>
        </a>
        <p class="cads-hero__eyebrow">JAGUAR RACING &#8212; 2026</p>
        <h1 class="cads-hero__title">CADS DEL BAJA</h1>
        <div class="cads-hero__divider"></div>
        <p class="cads-hero__desc">
            Ingenier&#237;a de precisi&#243;n minim&#233;trica. Cada componente dise&#241;ado, simulado
            y optimizado antes de tocar el metal.
        </p>
    </div>
</section>

<section class="cads-grid-section">

    <!-- 01 Suspension -->
    <article class="cad-item cad-item--left scroll-animate">
        <div class="cad-item__media">
            <img src="/gallery/cad-suspension.webp" alt="CAD de Suspensi&#243;n Baja SAE" class="cad-item__img" loading="lazy" decoding="async" />
            <div class="cad-item__img-overlay"></div>
        </div>
        <div class="cad-item__content">
            <span class="cad-item__number">01</span>
            <div class="cad-item__gold-line"></div>
            <h2 class="cad-item__title">CAD DE SUSPENSI&#211;N</h2>
            <span class="cad-item__date">01/04/2026</span>
            <p class="cad-item__desc">
                El coraz&#243;n del control: dise&#241;ado para resistir las condiciones m&#225;s extremas.
                Geometr&#237;a optimizada para absorber impactos sin comprometer la trayectoria.
            </p>
        </div>
    </article>

    <!-- 02 Armazon -->
    <article class="cad-item cad-item--right scroll-animate">
        <div class="cad-item__content">
            <span class="cad-item__number">02</span>
            <div class="cad-item__gold-line"></div>
            <h2 class="cad-item__title">CAD DEL ARMAZ&#211;N</h2>
            <span class="cad-item__date">01/04/2026</span>
            <p class="cad-item__desc">
                La columna vertebral del veh&#237;culo: ligereza y resistencia en una sola estructura.
                Cada tubo calculado para la distribuci&#243;n &#243;ptima de cargas.
            </p>
        </div>
        <div class="cad-item__media">
            <img src="/gallery/cad-armazon.webp" alt="CAD del Armaz&#243;n Baja SAE" class="cad-item__img" loading="lazy" decoding="async" />
            <div class="cad-item__img-overlay"></div>
        </div>
    </article>

    <!-- 03 Baleros -->
    <article class="cad-item cad-item--left scroll-animate">
        <div class="cad-item__media">
            <img src="/gallery/cad-baleros.webp" alt="CAD de Baleros Baja SAE" class="cad-item__img" loading="lazy" decoding="async" />
            <div class="cad-item__img-overlay"></div>
        </div>
        <div class="cad-item__content">
            <span class="cad-item__number">03</span>
            <div class="cad-item__gold-line"></div>
            <h2 class="cad-item__title">CAD DE BALEROS</h2>
            <span class="cad-item__date">01/04/2026</span>
            <p class="cad-item__desc">
                Precisi&#243;n minim&#233;trica para garantizar un movimiento fluido y eficiente.
                Tolerancias dise&#241;adas para soportar las cargas din&#225;micas de competencia.
            </p>
        </div>
    </article>

    <!-- 04 Volante -->
    <article class="cad-item cad-item--right scroll-animate">
        <div class="cad-item__content">
            <span class="cad-item__number">04</span>
            <div class="cad-item__gold-line"></div>
            <h2 class="cad-item__title">CAD DEL VOLANTE</h2>
            <span class="cad-item__date">01/04/2026</span>
            <p class="cad-item__desc">
                Interfaz hombre-m&#225;quina dise&#241;ada para una respuesta t&#225;ctil inmediata.
                Ergonom&#237;a optimizada para el piloto en condiciones extremas de vibraci&#243;n.
            </p>
        </div>
        <div class="cad-item__media">
            <img src="/gallery/cad-volante.webp" alt="CAD del Volante Baja SAE" class="cad-item__img" loading="lazy" decoding="async" />
            <div class="cad-item__img-overlay"></div>
        </div>
    </article>

    <!-- 05 Amortiguador -->
    <article class="cad-item cad-item--left scroll-animate">
        <div class="cad-item__media">
            <img src="/gallery/cad-amortiguador.webp" alt="CAD del Amortiguador Baja SAE" class="cad-item__img" loading="lazy" decoding="async" />
            <div class="cad-item__img-overlay"></div>
        </div>
        <div class="cad-item__content">
            <span class="cad-item__number">05</span>
            <div class="cad-item__gold-line"></div>
            <h2 class="cad-item__title">CAD DEL AMORTIGUADOR</h2>
            <span class="cad-item__date">01/04/2026</span>
            <p class="cad-item__desc">
                Ingenier&#237;a de detalle enfocada en la gesti&#243;n de energ&#237;a y confort.
                Curvas de fuerza-velocidad validadas mediante simulaci&#243;n din&#225;mica.
            </p>
        </div>
    </article>

    <!-- 06 Chasis -->
    <article class="cad-item cad-item--right scroll-animate">
        <div class="cad-item__content">
            <span class="cad-item__number">06</span>
            <div class="cad-item__gold-line"></div>
            <h2 class="cad-item__title">CAD DEL CHASIS</h2>
            <span class="cad-item__date">01/04/2026</span>
            <p class="cad-item__desc">
                La base de la innovaci&#243;n: donde todos los sistemas cobran vida.
                An&#225;lisis FEM integrado para garantizar la integridad estructural en pista.
            </p>
        </div>
        <div class="cad-item__media">
            <img src="/gallery/cad-chasis.webp" alt="CAD del Chasis Baja SAE" class="cad-item__img" loading="lazy" decoding="async" />
            <div class="cad-item__img-overlay"></div>
        </div>
    </article>

    <!-- 07 Completo -->
    <article class="cad-item cad-item--full scroll-animate">
        <div class="cad-item__media cad-item__media--wide">
            <img src="/gallery/cads-baja-thumb.webp" alt="CAD Completo del Baja SAE" class="cad-item__img" loading="lazy" decoding="async" />
            <div class="cad-item__img-overlay cad-item__img-overlay--bottom"></div>
            <div class="cad-item__full-content">
                <span class="cad-item__number">07</span>
                <div class="cad-item__gold-line"></div>
                <h2 class="cad-item__title">BAJA SAE &#8212; ENSAMBLAJE COMPLETO</h2>
                <span class="cad-item__date">01/04/2026</span>
                <p class="cad-item__desc" style="max-width:600px;">
                    Todos los sistemas integrados en un solo modelo. La visi&#243;n completa del prototipo
                    que llevamos a competencia.
                </p>
            </div>
        </div>
    </article>

</section>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap');

    /* HERO */
    .cads-hero {
        background: #000;
        position: relative;
        padding: 8rem 4rem 5rem;
        overflow: hidden;
    }

    .cads-hero__bg-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(184,150,12,0.035) 1px, transparent 1px),
            linear-gradient(90deg, rgba(184,150,12,0.035) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .cads-hero__inner {
        position: relative;
        z-index: 1;
        max-width: 900px;
        font-family: 'Montserrat', sans-serif;
    }

    .cads-back {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Montserrat', sans-serif;
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 0.2em;
        color: rgba(184,150,12,0.7);
        text-decoration: none;
        text-transform: uppercase;
        margin-bottom: 2rem;
        transition: color 0.2s ease;
    }

    .cads-back:hover { color: #b8960c; }

    .cads-back__arrow {
        font-size: 1.1rem;
        transition: transform 0.2s ease;
    }

    .cads-back:hover .cads-back__arrow { transform: translateX(-4px); }

    .cads-hero__eyebrow {
        font-family: 'Montserrat', sans-serif;
        font-weight: 500;
        font-size: 0.7rem;
        letter-spacing: 0.3em;
        color: rgba(184,150,12,0.6);
        text-transform: uppercase;
        margin: 0 0 0.75rem;
    }

    .cads-hero__title {
        font-family: 'Montserrat', sans-serif;
        font-weight: 800;
        font-size: clamp(2.5rem, 6vw, 5rem);
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0 0 1.5rem;
        line-height: 1;
    }

    .cads-hero__divider {
        width: 60px;
        height: 3px;
        background: #b8960c;
        margin-bottom: 1.5rem;
    }

    .cads-hero__desc {
        font-family: 'Montserrat', sans-serif;
        font-weight: 400;
        font-size: 1rem;
        color: rgba(255,255,255,0.5);
        line-height: 1.8;
        max-width: 560px;
        margin: 0;
    }

    /* GRID */
    .cads-grid-section {
        background: #000;
        padding: 2rem 0 6rem;
    }

    .cad-item {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 55vh;
        border-top: 1px solid rgba(255,255,255,0.04);
        font-family: 'Montserrat', sans-serif;
    }

    .cad-item--full {
        grid-template-columns: 1fr;
        min-height: 60vh;
    }

    .cad-item__media {
        position: relative;
        overflow: hidden;
        background: #080808;
    }

    .cad-item__media--wide { min-height: 60vh; }

    .cad-item__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        transform: scale(1.04);
        transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        filter: grayscale(15%);
    }

    .cad-item:hover .cad-item__img {
        transform: scale(1.1);
        filter: grayscale(0%);
    }

    .cad-item__img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.05) 100%);
    }

    .cad-item__img-overlay--bottom {
        background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.35) 55%, transparent 100%);
    }

    .cad-item__content {
        background: #050505;
        padding: 3.5rem 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        border-left: 1px solid rgba(184,150,12,0.07);
    }

    .cad-item--right .cad-item__content {
        border-left: none;
        border-right: 1px solid rgba(184,150,12,0.07);
    }

    .cad-item__number {
        font-weight: 800;
        font-size: 4rem;
        color: rgba(184,150,12,0.07);
        line-height: 1;
        letter-spacing: -0.02em;
        display: block;
        margin-bottom: -0.75rem;
    }

    .cad-item__gold-line {
        width: 40px;
        height: 2px;
        background: #b8960c;
        margin-bottom: 1.25rem;
    }

    .cad-item__title {
        font-weight: 700;
        font-size: clamp(1rem, 2.2vw, 1.5rem);
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 0 0 0.5rem;
        line-height: 1.2;
    }

    .cad-item__date {
        font-weight: 500;
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        color: rgba(184,150,12,0.6);
        text-transform: uppercase;
        display: block;
        margin-bottom: 1rem;
    }

    .cad-item__desc {
        font-weight: 400;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.45);
        line-height: 1.8;
        margin: 0;
    }

    .cad-item__full-content {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        z-index: 2;
        padding: 3rem 4rem;
    }

    /* Responsive */
    @media (max-width: 900px) {
        .cad-item {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .cad-item__media { min-height: 50vw; }

        .cad-item--right .cad-item__content { order: -1; }
        .cad-item--right .cad-item__media   { order: 1; }

        .cad-item__content {
            border-left: none !important;
            border-right: none !important;
            border-top: 1px solid rgba(184,150,12,0.07);
            padding: 2.5rem 2rem;
        }

        .cads-hero { padding: 6rem 1.5rem 3rem; }

        .cad-item__full-content { padding: 2rem 1.5rem; }
    }
</style>
