---
// Interfaz Educativa Jaguar Racing - Metodología y Fundamentos (Z-Pattern Layout)
const areas = [
    {
        id: 'powertrain',
        title: 'TRANSFERENCIA DE POTENCIA',
        subtitle: 'POWERTRAIN',
        desc: 'Análisis de la cadena cinemática desde el motor reglamentario hasta las ruedas. Diseño y calibración de la transmisión continuamente variable (CVT) y la caja reductora para optimizar el torque y la velocidad en terrenos irregulares.',
        videoFile: 'F-GB.mp4', 
    },
    {
        id: 'suspension',
        title: 'CINEMÁTICA Y AMORTIGUACIÓN',
        subtitle: 'SUSPENSIÓN',
        desc: 'Estudio de la dinámica vehicular enfocado en absorber impactos extremos. Simulación de la geometría de doble horquilla para mantener el contacto óptimo del neumático, controlando el centro de balanceo y el recorrido total.',
        videoFile: 'Front susp der.mp4',
    },
    {
        id: 'frenos',
        title: 'SISTEMA DE FRENADO Y SEGURIDAD',
        subtitle: 'FRENOS',
        desc: 'Dimensionamiento hidráulico y térmico del sistema de detención. Cálculo de fuerzas de fricción y diseño de rotores para garantizar la máxima capacidad de frenado y disipación de calor bajo normativas estrictas de competencia.',
        videoFile: 'B-GB.mp4',
    },
    {
        id: 'direccion',
        title: 'GEOMETRÍA DE MANIOBRA',
        subtitle: 'DIRECCIÓN',
        desc: 'Diseño del mecanismo de piñón y cremallera para una respuesta táctil precisa. Análisis de la geometría de Ackermann para minimizar el radio de giro y optimizar el control del piloto en circuitos de alta exigencia técnica.',
        videoFile: 'Ensamble Housin JR25.mp4',
    }
];
---

<section class="eng-section">
    <div class="eng-container">
        {areas.map((area, i) => (
            /* La clase 'is-reversed' se añade a los índices impares (1, 3, 5) para alternar el layout */
            <article class={`eng-feature ${i % 2 !== 0 ? 'is-reversed' : ''}`} id={`feature-${area.id}`}>
                <div class="feature-video-wrapper">
                    <div class="video-frame">
                        <video 
                            src={`/public/actualizaciones/videos/${area.videoFile}`}
                            class="cad-native-video"
                            autoplay 
                            loop 
                            muted 
                            playsinline
                            disablepictureinpicture
                        ></video>
                    </div>
                </div>
                
                <div class="feature-info">
                    <span class="feature-subtitle">{area.subtitle}</span>
                    <h2 class="feature-title">{area.title}</h2>
                    <p class="feature-desc">{area.desc}</p>
                </div>
            </article>
        ))}
    </div>
</section>

<style>
    .eng-section {
        background: var(--bg-black);
        padding: 4rem clamp(1.5rem, 5vw, 4rem) 6rem;
    }

    .eng-container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 6rem; /* Espacio generoso entre cada sección de ingeniería */
    }

    .eng-feature {
        display: grid;
        grid-template-columns: 1fr 1fr; /* Mitad video, mitad texto */
        gap: 4rem;
        align-items: center;
    }

    /* Aquí está la magia: si tiene la clase is-reversed, el texto va a la izquierda y el video a la derecha */
    .eng-feature.is-reversed {
        direction: rtl; /* Invierte el orden del grid */
    }

    /* Como invertimos la dirección del grid, debemos devolverle la dirección normal al contenido */
    .eng-feature.is-reversed > * {
        direction: ltr; 
    }

    /* --- ESTILOS DEL VIDEO --- */
    .feature-video-wrapper {
        position: relative;
        width: 100%;
    }

    .video-frame {
        position: relative;
        padding-top: 56.25%; /* 16:9 Aspect Ratio */
        background: #050505;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(166, 124, 0, 0.15);
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        transition: transform 0.4s ease, box-shadow 0.4s ease;
    }

    /* Pequeño efecto hover para que se sienta premium */
    .video-frame:hover {
        transform: translateY(-5px);
        box-shadow: 0 30px 50px rgba(0,0,0,0.6);
        border-color: rgba(166, 124, 0, 0.3);
    }

    .cad-native-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover; 
        pointer-events: none; 
    }

    /* --- ESTILOS DEL TEXTO --- */
    .feature-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .feature-subtitle {
        color: var( --text-gray);
        font-family: var(--font-main);
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 0.5rem;
        display: block;
    }

    .feature-desc {
        color: var(--text-gray);
        line-height: 1.7;
        margin: 0;
        max-width: 90%; /* Para que las líneas no se vean eternas */
    }

    /* --- RESPONSIVE (MÓVILES) --- */
    @media (max-width: 900px) {
        .eng-container {
            gap: 4rem; /* Menos espacio en móvil */
        }

        .eng-feature, 
        .eng-feature.is-reversed {
            grid-template-columns: 1fr; /* Apila uno sobre otro */
            direction: ltr; /* Quita la inversión del grid en móvil */
            gap: 2rem;
            text-align: center;
        }

        .feature-info {
            align-items: center;
        }

        .feature-title {
            text-align: center;
        }

        .feature-desc {
            max-width: 100%;
            text-align: center;
        }
    }
</style>