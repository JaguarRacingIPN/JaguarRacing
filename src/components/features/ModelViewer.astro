---
// Componente minimalista de visor 3D para Jaguar Racing - Compacto
---

<section class="render-hero">
    <div class="render-hero__inner">
        <h1>Render Interactivo</h1>
        <p>
            Explora los conceptos mecánicos y las áreas de ingeniería que conforman un vehículo Baja SAE. Los modelos y referencias a continuación ilustran nuestro proceso teórico de desarrollo y análisis.
        </p>
    </div>
</section>

<section class="render-viewer-section">
    <div class="render-viewer-container">
        <canvas id="render-canvas" class="render-canvas"></canvas>
        
        <div class="render-viewer__loading" id="viewer-loading">
            <div class="loading-spinner"></div>
            <p>Sincronizando telemetría 3D...</p>
        </div>

        <div class="render-viewer__controls">
            <button class="viewer-ctrl active" id="ctrl-rotate" title="Rotación automática">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"></path><polyline points="21 3 21 8 16 8"></polyline></svg>
            </button>
            <button class="viewer-ctrl" id="ctrl-reset" title="Reiniciar vista">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
            <button class="viewer-ctrl" id="ctrl-wireframe" title="Vista wireframe">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
            </button>
        </div>
    </div>
</section>

<style>
    /* ─── Hero Section (Minimalista Compacto) ──────────────────── */
    .render-hero {
        background: var(--bg-black);
        padding: 6rem 2rem 1.5rem; 
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .render-hero__inner {
        position: relative;
        z-index: 1;
        max-width: 700px;
    }

    .render-hero__inner p {
        margin-top: 0.5rem;
        margin-bottom: 0;
        font-size: 0.9rem;
    }

    /* ─── Viewer Section ───────── */
    .render-viewer-section {
        background: var(--bg-black);
        padding: 0 0 2rem; 
    }

    .render-viewer-container {
        position: relative;
        width: min(94%, 85rem);
        margin: 0 auto;
        
        height: 60vh; 
        max-height: 550px; 
        min-height: 350px;
        
        background: #050505;
        border: 1px solid rgba(166, 124, 0, 0.15);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    }

    .render-canvas {
        width: 100%;
        height: 100%;
        outline: none;
        display: block;
    }

    /* ─── Loading State ────────────────────────────────────────── */
    .render-viewer__loading {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: var(--bg-black);
        z-index: 10;
        transition: opacity 0.5s ease;
        color: var(--text-gray);
    }

    .render-viewer__loading.hidden {
        opacity: 0;
        pointer-events: none;
    }

    .loading-spinner {
        width: 45px;
        height: 45px;
        border: 3px solid rgba(166, 124, 0, 0.1);
        border-top-color: var(--jaguar-gold);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 1.5rem;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* ─── Controls ────────────────────────────────────────────── */
    .render-viewer__controls {
        position: absolute;
        bottom: 1.5rem;
        right: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        z-index: 5;
    }

    .viewer-ctrl {
        width: 44px;
        height: 44px;
        background: rgba(0, 0, 0, 0.85);
        border: 1px solid rgba(166, 124, 0, 0.25);
        color: var(--text-white);
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
        transition: all 0.3s ease;
    }

    .viewer-ctrl:hover, .viewer-ctrl.active {
        border-color: var(--jaguar-gold);
        color: var(--jaguar-gold);
        background: rgba(166, 124, 0, 0.1);
        transform: scale(1.05);
    }

    /* ─── Responsive ───────────────────────────────────────────── */
    @media (max-width: 900px) {
        .render-hero { padding: 5rem 1.5rem 1rem; }
        .render-viewer-section { padding: 0 0 1.5rem; }
        .render-viewer-container { 
            height: 55vh; 
            aspect-ratio: auto; 
        }
    }
</style>

<script>
    import * as THREE from 'three';
    // @ts-expect-error - No type definitions available for GLTFLoader
    import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
    import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

    let cleanupViewer: (() => void) | undefined;

    const getThemeColor = (variableName: string, fallback = ''): string => {
        const value = getComputedStyle(document.documentElement).getPropertyValue(variableName).trim();
        return value || fallback;
    };

    const disposeMaterial = (material: any): void => {
        if (Array.isArray(material)) {
            material.forEach(disposeMaterial);
            return;
        }
        material?.dispose?.();
    };

    const disposeObject = (object: any): void => {
        object.traverse((child: any) => {
            if (child.geometry) child.geometry.dispose();
            if (child.material) disposeMaterial(child.material);
        });
    };

    async function initRenderViewer() {
        const canvas = document.getElementById('render-canvas');
        const container = document.querySelector('.render-viewer-container');
        const loadingEl = document.getElementById('viewer-loading');
        const btnRotate = document.getElementById('ctrl-rotate');
        const btnReset = document.getElementById('ctrl-reset');
        const btnWireframe = document.getElementById('ctrl-wireframe');

        if (!canvas || !container) return undefined;

        const bgDark = getThemeColor('--bg-black', 'black');
        const gold = getThemeColor('--jaguar-gold', '#A67C00');

        const scene = new THREE.Scene();
        scene.background = new THREE.Color(bgDark);
        scene.fog = new THREE.FogExp2(bgDark, 0.008);

        const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 1000);
        camera.position.set(0, 1.8, 8);

        const renderer = new THREE.WebGLRenderer({ canvas: canvas as HTMLCanvasElement, antialias: true });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.shadowMap.enabled = true;

        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.autoRotate = true;
        controls.autoRotateSpeed = 0.8;
        controls.minDistance = 4;
        controls.maxDistance = 16;
        controls.target.set(0, 0, 0);

        scene.add(new THREE.AmbientLight(0xffffff, 0.42));
        const goldLight = new THREE.DirectionalLight(gold, 1.15);
        goldLight.position.set(5, 8, 5);
        scene.add(goldLight);

        const gridHelper = new THREE.GridHelper(20, 20, new THREE.Color(gold), new THREE.Color('rgb(22, 22, 22)'));
        scene.add(gridHelper);

        const placeholder = new THREE.Mesh(
            new THREE.BoxGeometry(3, 1.5, 5),
            new THREE.MeshStandardMaterial({ color: gold, metalness: 0.9, roughness: 0.3 })
        );
        scene.add(placeholder);

        let loadedModel: any = null;
        let isWireframe = false;
        let animId = 0;
        let resizeObserver: ResizeObserver | undefined;

        const setWireframe = (root: any, enabled: boolean): void => {
            if (!root) return;
            root.traverse((child: any) => {
                if (child.isMesh && child.material) child.material.wireframe = enabled;
            });
        };

        const applySize = (): void => {
            const width = container.clientWidth;
            const height = container.clientHeight;
            camera.aspect = width / height;
            camera.updateProjectionMatrix();
            renderer.setSize(width, height, false);
        };

        btnRotate?.addEventListener('click', () => {
            controls.autoRotate = !controls.autoRotate;
            btnRotate.classList.toggle('active', controls.autoRotate);
        });

        btnReset?.addEventListener('click', () => {
            controls.reset();
            controls.target.set(0, 0, 0);
            controls.update();
        });

        btnWireframe?.addEventListener('click', () => {
            isWireframe = !isWireframe;
            btnWireframe.classList.toggle('active', isWireframe);
            setWireframe(loadedModel ?? placeholder, isWireframe);
        });

        // Usamos el GLTFLoader para tu nuevo archivo
        const loader = new GLTFLoader();
        loader.load('/models/baja-chasis-2026.glb', (gltf: any) => {
            scene.remove(placeholder);
            
            const model = gltf.scene; // Extrayendo la escena del contenedor gltf
            
            model.traverse((child: any) => {
                if (child.isMesh) {
                    child.material = new THREE.MeshStandardMaterial({ color: gold, metalness: 0.8, roughness: 0.25 });
                    child.castShadow = true;
                }
            });
            
            const box = new THREE.Box3().setFromObject(model);
            const center = box.getCenter(new THREE.Vector3());
            const size = box.getSize(new THREE.Vector3());
            const scale = 4 / Math.max(size.x, size.y, size.z);
            
            model.scale.setScalar(scale);
            model.position.sub(center.multiplyScalar(scale));
            
            scene.add(model);
            loadedModel = model;
            loadingEl?.classList.add('hidden');
        }, undefined, () => loadingEl?.classList.add('hidden'));

        resizeObserver = new ResizeObserver(applySize);
        resizeObserver.observe(container);
        applySize();

        const animate = () => {
            animId = requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
        };
        animate();

        return () => {
            cancelAnimationFrame(animId);
            resizeObserver?.disconnect();
            controls.dispose();
            disposeObject(scene);
            renderer.dispose();
        };
    }

    document.addEventListener('astro:page-load', async () => {
        if (cleanupViewer) cleanupViewer();
        cleanupViewer = await initRenderViewer();
    });

    document.addEventListener('astro:before-swap', () => {
        if (cleanupViewer) {
            cleanupViewer();
            cleanupViewer = undefined;
        }
    });
</script>